          "name": "T21 — Cliente cria pedido válido (positivo, 201)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitId\": {{unitId}},\n  \"canalPedido\": \"APP\",\n  \"items\": [\n    { \"productId\": {{productId}}, \"quantity\": 2 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos"]
            },
            "description": "Cliente Maria cria pedido válido. Esperado: 201, status WAITING_PAYMENT, payment PENDING criado."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('currentStatus WAITING_PAYMENT', () => pm.expect(json.currentStatus).to.eql('WAITING_PAYMENT'));",
                  "pm.test('canalPedido APP', () => pm.expect(json.canalPedido).to.eql('APP'));",
                  "pm.test('Tem items', () => pm.expect(json.items).to.be.an('array').that.has.lengthOf(1));",
                  "pm.test('latestPayment PENDING', () => pm.expect(json.latestPayment.status).to.eql('PENDING'));",
                  "pm.collectionVariables.set('orderId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
