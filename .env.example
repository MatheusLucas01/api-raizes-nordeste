DATABASE_URL="postgresql://USUARIO_BANCO:SENHA_BANCO@HOST:PORT/NOME_BANCO?schema=public"

# JWT — generate strong random secrets (e.g. `openssl rand -base64 64`)
JWT_SECRET="change-me-to-a-strong-random-secret"
JWT_REFRESH_SECRET="change-me-to-a-different-strong-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=8000
