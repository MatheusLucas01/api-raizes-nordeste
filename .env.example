# ============================================================
# CONFIGURAÇÃO DA APLICAÇÃO
# Copie este arquivo para .env e ajuste conforme seu ambiente.
# ============================================================

# ----- BANCO DE DADOS (PostgreSQL) -----
# Opção A (recomendada) — usando o docker-compose.yml deste projeto:
DATABASE_URL="postgresql://postgres:admin@localhost:5434/api_raizes?schema=public"

# Opção B — PostgreSQL instalado nativamente (descomente e ajuste se preferir):
# DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/api_raizes?schema=public"

# ----- JWT -----
# IMPORTANTE: gere segredos fortes para produção.
# Para gerar, rode: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET="change-me-to-a-strong-random-secret"
JWT_REFRESH_SECRET="change-me-to-a-different-strong-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ----- SERVIDOR -----
PORT=8000
