generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============

enum Role {
  CLIENT
  ATTENDANT
  KITCHEN
  ADMIN
  MANAGER
}

enum OrderChannel {
  APP
  TOTEM
  BALCAO
  PICKUP
  WEB
}

enum OrderStatus {
  WAITING_PAYMENT
  IN_PREPARATION
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REFUSED
}

enum MovementType {
  IN
  OUT
}

// ============ MODELS ============

model User {
  id               Int      @id @default(autoincrement())
  name             String
  email            String   @unique
  passwordHash     String
  role             Role     @default(CLIENT)
  lgpdConsent      Boolean
  loyaltyPoints    Int      @default(0)
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orders         Order[]
  stockMovements StockMovement[]
  statusChanges  OrderStatusHistory[]
}

model Unit {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productUnits   ProductUnit[]
  stockMovements StockMovement[]
  orders         Order[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productUnits   ProductUnit[]
  stockMovements StockMovement[]
  orderItems     OrderItem[]
}

model ProductUnit {
  productId       Int
  unitId          Int
  localPrice      Decimal @db.Decimal(10, 2)
  currentQuantity Int     @default(0)
  isAvailable     Boolean @default(true)

  product Product @relation(fields: [productId], references: [id])
  unit    Unit    @relation(fields: [unitId], references: [id])

  @@id([productId, unitId])
  @@index([unitId])
}

model StockMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  unitId    Int
  type      MovementType
  quantity  Int
  reason    String?
  userId    Int
  createdAt DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
  unit    Unit    @relation(fields: [unitId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId, unitId])
  @@index([userId])
}

model Order {
  id              Int          @id @default(autoincrement())
  clientId        Int?
  unitId          Int
  canalPedido     OrderChannel
  currentStatus   OrderStatus  @default(WAITING_PAYMENT)
  subtotal        Decimal      @db.Decimal(10, 2)
  discountApplied Decimal      @default(0) @db.Decimal(10, 2)
  total           Decimal      @db.Decimal(10, 2)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  client        User?                @relation(fields: [clientId], references: [id])
  unit          Unit                 @relation(fields: [unitId], references: [id])
  items         OrderItem[]
  payments      Payment[]
  statusHistory OrderStatusHistory[]

  @@index([unitId])
  @@index([clientId])
  @@index([canalPedido])
  @@index([currentStatus])
}

model OrderItem {
  id            Int     @id @default(autoincrement())
  orderId       Int
  productId     Int
  quantity      Int
  priceSnapshot Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Payment {
  id            Int           @id @default(autoincrement())
  orderId       Int
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  attemptNumber Int
  providerRef   String?
  createdAt     DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@unique([orderId, attemptNumber])
  @@index([orderId])
}

model OrderStatusHistory {
  id             Int          @id @default(autoincrement())
  orderId        Int
  previousStatus OrderStatus?
  newStatus      OrderStatus
  changedById    Int?
  reason         String?
  createdAt      DateTime     @default(now())

  order     Order @relation(fields: [orderId], references: [id])
  changedBy User? @relation(fields: [changedById], references: [id])

  @@index([orderId, createdAt])
}
